# Copy to `.env.local` for local dev (never commit secrets).

# Network
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Contract IDs (optional — defaults exist in src/lib/config.ts for testnet)
# NEXT_PUBLIC_TOKEN_CONTRACT=
# NEXT_PUBLIC_VAULT_CONTRACT=

# Optional: GitHub repo link in footer
# NEXT_PUBLIC_GITHUB_REPO=https://github.com/your-org/your-repo

# Server-only: mint API /api/faucet (never expose to client)
# DEPLOYER_SECRET_KEY=
